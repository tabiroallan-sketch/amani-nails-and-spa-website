# =============================================================================
# Amani Nails & Spa — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values. For production, set these as
# Cloudflare Pages/Workers secrets via `wrangler secret put <NAME>`.
# =============================================================================

# ── Cloudflare Turnstile ────────────────────────────────────────────────────
# https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ── Resend (Email Notifications) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Africa's Talking (WhatsApp/SMS Notifications) ───────────────────────────
# https://account.africastalking.com/apps
AFRICASTALKING_API_KEY=xxxxxxxxxxxx

# ── Cloudflare D1 (Database) ────────────────────────────────────────────────
# Database will be bound at runtime; no variable needed for Wrangler.
# Create via: npx wrangler d1 create amani-spa

# ── Cloudflare R2 (Asset Storage) ───────────────────────────────────────────
# Bucket bound at runtime; create via: npx wrangler r2 bucket create amani-spa-assets

# ── Cloudflare KV (Rate Limiting, Sessions) ─────────────────────────────────
# Namespace bound at runtime; create via: npx wrangler kv namespace create amani-spa-kv

# ── API URL (Frontend → Worker) ─────────────────────────────────────────────
# Used by Astro frontend to call the API worker.
PUBLIC_API_URL=https://api.amanispanairobi.com

# ── Google Maps (Contact Page Embed) ────────────────────────────────────────
PUBLIC_GOOGLE_MAPS_KEY=
