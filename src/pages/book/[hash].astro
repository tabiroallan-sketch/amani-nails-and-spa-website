---
import BaseLayout from "../../components/layout/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { hash: "placeholder" } }];
}

const { hash } = Astro.params;
---

<BaseLayout
  title="Booking Confirmed — Amani Nails & Spa | Nairobi"
  description="Your appointment at Amani Nails & Spa in Westlands, Nairobi has been confirmed. We look forward to welcoming you for your manicure, massage, or spa experience."
  noindex={true}
>
  <section class="section-padding bg-ivory-silk pt-32">
    <div class="container-luxury">
      <div class="max-w-lg mx-auto text-center">
        <div class="w-16 h-16 rounded-full bg-sage-whisper mx-auto flex items-center justify-center mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C1810" stroke-width="2.5">
            <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h1 class="font-display text-[clamp(1.75rem,4vw,2.5rem)] font-semibold text-espresso text-balance">
          Booking Confirmed
        </h1>
        <p class="mt-4 font-body text-base text-warm-taupe">
          Your appointment at Amani Nails & Spa has been booked. A confirmation email is on its way.
        </p>

        <div class="mt-8 p-6 rounded-[var(--radius-card)] bg-champagne text-left">
          <p class="font-body text-xs text-warm-taupe mb-1">Reference</p>
          <p class="font-display text-xl font-semibold text-gold-leaf mb-4">{hash}</p>
          <p class="font-body text-sm text-espresso">A confirmation has been sent to your email with all the details.</p>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/"
            class="px-8 py-3 bg-gold-leaf text-ivory-silk font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full hover:bg-espresso transition-all"
          >
            Return Home
          </a>
          <a
            href="/booking"
            class="px-8 py-3 border border-gold-leaf text-gold-leaf font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full hover:bg-gold-leaf hover:text-espresso transition-all"
          >
            Book Again
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
