---
import BaseLayout from "../components/layout/BaseLayout.astro";
import GalleryFilter from "../components/sections/GalleryFilter.tsx";
import BeforeAfter from "../components/sections/BeforeAfter.tsx";
import { breadcrumbSchema, imageGallerySchema } from "../lib/seo";
import { getCollection } from "astro:content";

const galleryItems = await getCollection("gallery");
galleryItems.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const serialized = galleryItems.map((item) => ({
  slug: item.slug,
  title: item.data.title,
  category: item.data.category,
  image: item.data.image,
  before: item.data.before,
  after: item.data.after,
  description: item.data.description,
  featured: item.data.featured ?? false,
}));

const beforeAfterItems = serialized.filter((item) => item.category === "before-after" && item.before && item.after);
const galleryForSchema = serialized.map((item) => ({
  url: item.image || item.after || "",
  caption: item.title,
}));
---

<BaseLayout
  title="Gallery — Amani Nails & Spa | Nail Art & Spa Transformations in Nairobi"
  description="Browse our portfolio of nail artistry, spa experiences, and transformations at Amani Nails & Spa in Nairobi, Kenya. See why we're the best nail salon and luxury spa in Westlands."
  schemas={[
    breadcrumbSchema([
      { name: "Home", url: "/" },
      { name: "Gallery", url: "/gallery" },
    ]),
    imageGallerySchema(galleryForSchema),
  ]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ivory-silk pt-32 pb-16 md:pb-20">
    <div class="absolute inset-0 bg-gradient-to-b from-champagne/30 via-ivory-silk to-ivory-silk pointer-events-none" />
    <div class="container-luxury relative z-10 text-center">
      <p class="font-accent text-xs uppercase tracking-[0.2em] text-warm-taupe mb-4" data-animate>
        Portfolio
      </p>
      <h1 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-semibold text-espresso text-balance leading-[1.1]" data-animate data-delay="100">
        Our <span class="gradient-text-gold">Gallery</span>
      </h1>
      <p class="mt-4 font-body text-base md:text-lg text-warm-taupe max-w-2xl mx-auto text-balance" data-animate data-delay="200">
        A visual journey through our work — from intricate nail art to serene spa moments and stunning transformations.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="section-padding bg-ivory-silk -mt-1">
    <div class="container-luxury">
      <GalleryFilter client:load items={serialized} />
    </div>
  </section>

  <!-- Before & After Section -->
  {beforeAfterItems.length > 0 && (
    <section class="section-padding bg-champagne/50">
      <div class="container-luxury">
        <div class="text-center mb-12" data-animate>
          <p class="font-accent text-xs uppercase tracking-[0.2em] text-gold-leaf-dark mb-3">
            Transformations
          </p>
          <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] font-semibold text-espresso text-balance">
            Before & After
          </h2>
          <p class="mt-3 font-body text-base text-warm-taupe max-w-xl mx-auto">
            Real results from our clients — see the difference professional care makes.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto" data-animate-stagger>
          {beforeAfterItems.map((item) => (
            <BeforeAfter
              client:load
              beforeImage={item.before!}
              afterImage={item.after!}
              title={item.title}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-espresso relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(201,168,108,0.08),transparent_60%)] pointer-events-none" />
    <div class="container-luxury relative z-10 text-center">
      <h2 class="font-display text-[clamp(1.75rem,4vw,2.75rem)] font-semibold text-ivory text-balance" data-animate>
        Ready for Your Transformation?
      </h2>
      <p class="mt-4 font-body text-base text-ivory/70 max-w-lg mx-auto" data-animate data-delay="100">
        Book your appointment today and experience the Amani difference.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4" data-animate data-delay="200">
        <a
          href="/booking"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-gold-leaf text-espresso font-accent text-sm uppercase tracking-[0.1em] font-semibold transition-all duration-[var(--duration-normal)] hover:bg-champagne-gold hover:shadow-glow-gold"
        >
          Book an Appointment
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="/services"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-ivory/20 text-ivory font-accent text-sm uppercase tracking-[0.1em] font-semibold transition-all duration-[var(--duration-normal)] hover:bg-ivory/10"
        >
          View Services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
