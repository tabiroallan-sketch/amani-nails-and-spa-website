---
interface DirectionCard {
  icon: string;
  title: string;
  description: string;
}

const directions: DirectionCard[] = [
  {
    icon: "car",
    title: "By Car",
    description:
      "Free parking available at Westgate Mall, 2-minute walk to our entrance.",
  },
  {
    icon: "bus",
    title: "By Matatu",
    description:
      "Public transport along Waiyaki Way, alight at Westlands Stage.",
  },
  {
    icon: "navigation",
    title: "By Ride-Hailing",
    description:
      'Uber/Bolt to "Westlands, opposite Westgate Mall".',
  },
];

const icons: Record<string, string> = {
  car: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17a2 2 0 0 1-2-2V9a1 1 0 0 1 1-1h1l2-4h8l2 4h1a1 1 0 0 1 1 1v6a2 2 0 0 1-2 2"/><circle cx="7" cy="11" r="1"/><circle cx="17" cy="11" r="1"/><path d="M9 17h6"/></svg>',
  bus: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M3 10h18"/><circle cx="8" cy="17" r="2"/><circle cx="16" cy="17" r="2"/><path d="M8 21v-2"/><path d="M16 21v-2"/></svg>',
  navigation:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>',
};
---

<section class="section-padding bg-warm-white overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
        Getting Here
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
        How to Find <span class="gradient-text-gold">Us</span>
      </h2>
      <p class="mt-4 font-body text-base text-taupe mb-14">
        Conveniently located in Westlands, Nairobi — we're easy to reach from
        anywhere in the city.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" data-animate-stagger>
      {directions.map((d) => (
        <div class="rounded-[var(--radius-xl)] bg-ivory-silk p-6 md:p-8 shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gold-leaf/10 text-gold-leaf mb-5">
            <span class="h-5 w-5" set:html={icons[d.icon]} />
          </div>
          <h3 class="font-display text-lg font-semibold text-espresso mb-3">
            {d.title}
          </h3>
          <p class="font-body text-sm text-taupe leading-relaxed">
            {d.description}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-12" data-reveal>
      <div class="relative aspect-[16/9] lg:aspect-[21/9] rounded-[var(--radius-2xl)] overflow-hidden shadow-soft bg-ivory-silk">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.754!2d36.8033!3d-1.2611!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMcKwMTUnNDAuMCJTIDM2wrA0OCcxMS45IkU!5e0!3m2!1sen!2ske!4v1"
          width="100%"
          height="100%"
          style="border:0; min-height: 300px; position: absolute; inset: 0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Amani Nails & Spa location in Westlands, Nairobi"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-gold-leaf/10 rounded-[var(--radius-2xl)] pointer-events-none" />
      </div>
    </div>
  </div>
</section>
