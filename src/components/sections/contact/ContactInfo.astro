---
interface ContactCard {
  label: string;
  value: string;
  href?: string;
  icon: string;
}

const cards: ContactCard[] = [
  {
    label: "WhatsApp",
    value: "+254 700 000 000",
    href: "https://wa.me/254700000000",
    icon: "whatsapp",
  },
  {
    label: "Phone",
    value: "+254 700 000 000",
    href: "tel:+254700000000",
    icon: "phone",
  },
  {
    label: "Email",
    value: "hello@amanispanairobi.com",
    href: "mailto:hello@amanispanairobi.com",
    icon: "mail",
  },
  {
    label: "Address",
    value: "Westlands, Nairobi, Kenya\n(Next to Westgate Shopping Mall)",
    icon: "map-pin",
  },
];

const icons: Record<string, string> = {
  whatsapp:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>',
  phone:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  mail:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  "map-pin":
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
};
---

<section class="section-padding bg-ivory-silk overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
        Reach Out
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
        Let's <span class="gradient-text-gold">Connect</span>
      </h2>
      <p class="mt-4 font-body text-base text-taupe mb-14">
        Choose the channel that's most convenient for you. We look forward to
        hearing from you.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6" data-animate-stagger>
      {cards.map((card) => (
        <div class="rounded-[var(--radius-xl)] bg-warm-white p-6 md:p-8 shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated">
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-gold-leaf/10 text-gold-leaf">
              <span class="h-5 w-5" set:html={icons[card.icon]} />
            </div>
            <div class="min-w-0">
              <p class="font-body text-xs uppercase tracking-[0.1em] text-taupe-warm font-semibold mb-0.5">
                {card.label}
              </p>
              {"href" in card && card.href ? (
                <a
                  href={card.href}
                  target={card.href.startsWith("https") ? "_blank" : undefined}
                  rel={card.href.startsWith("https") ? "noopener noreferrer" : undefined}
                  class="font-display text-base font-medium text-espresso hover:text-gold-leaf transition-colors duration-[var(--duration-fast)]"
                >
                  {card.value}
                </a>
              ) : (
                <p class="font-display text-base font-medium text-espresso leading-relaxed whitespace-pre-line">
                  {card.value}
                </p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
