---
import HeroAnimation from "./HeroAnimation.astro";
---

<section
  class="relative min-h-[70svh] flex items-center justify-center overflow-hidden bg-ivory-silk pt-20"
  data-hero-section
>
  <div
    data-hero-overlay
    class="pointer-events-none absolute inset-0 z-[2] opacity-0"
  >
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(249,246,240,0)_0%,rgba(249,246,240,0.3)_50%,rgba(249,246,240,0.7)_100%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(201,168,108,0.04)_0%,transparent_60%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(232,180,184,0.03)_0%,transparent_50%)]" />
    <div
      class="absolute inset-0 opacity-[0.015]"
      style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23000000' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\"); background-repeat: repeat;"
    />
  </div>

  <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-ivory-silk to-transparent pointer-events-none z-[3]" />

  <HeroAnimation />

  <div class="container-luxury text-center relative z-10" data-hero-content>
    <p data-hero-subtitle class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-6">
      Get in Touch
    </p>

    <h1
      class="font-display text-[clamp(2.5rem,8vw,5rem)] font-semibold text-espresso text-balance leading-[1.05]"
      data-hero
    >
      We'd Love to<br />
      <span class="gradient-text-gold">Hear from You</span>
    </h1>

    <p data-hero-desc class="mt-6 font-body text-lg text-taupe max-w-2xl mx-auto text-balance">
      Whether you have a question, want to book an appointment, or simply want to
      learn more about what we offer — we're here for you.
    </p>

    <div data-hero-cta class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contact-form"
        class="group relative inline-flex items-center gap-2.5 px-10 py-5 bg-gold-leaf text-espresso font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] shadow-soft hover:shadow-elevated hover:bg-espresso hover:text-ivory-silk active:scale-[0.97] overflow-hidden"
      >
        <span class="relative z-10">Send a Message</span>
        <svg
          class="relative z-10 h-4 w-4 transition-transform duration-[var(--duration-normal)] group-hover:translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="22" y1="2" x2="11" y2="13" />
          <polygon points="22 2 15 22 11 13 2 9 22 2" />
        </svg>
        <span class="absolute inset-0 -translate-x-full transition-transform duration-[var(--duration-slow)] ease-[var(--ease-out-expo)] group-hover:translate-x-0 bg-espresso rounded-full" />
      </a>

      <a
        href="https://wa.me/254700000000"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 px-8 py-4 border border-gold-leaf/40 text-espresso font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:bg-champagne hover:border-gold-leaf active:scale-[0.97]"
      >
        <svg
          class="h-5 w-5 text-gold-leaf transition-transform duration-[var(--duration-fast)] group-hover:scale-110"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        <span class="text-espresso">WhatsApp</span>
      </a>
    </div>
  </div>

  <div
    data-hero-scroll
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-taupe"
  >
    <span class="font-body text-[10px] uppercase tracking-[0.2em]">Scroll</span>
    <div class="flex flex-col items-center gap-1">
      <div class="h-8 w-[1px] bg-gradient-to-b from-taupe/50 to-transparent" />
      <svg
        class="h-3 w-3 animate-float text-taupe/40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </div>
  </div>

  <div class="pointer-events-none absolute left-1/4 top-1/4 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-champagne-gold/5 blur-3xl" />
  <div class="pointer-events-none absolute right-1/4 bottom-1/4 h-80 w-80 translate-x-1/2 translate-y-1/2 rounded-full bg-rose-gold/5 blur-3xl" />

  <style>
    .animate-float {
      animation: float 3s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(4px); }
    }
  </style>
</section>
