---
import Image from "../../ui/Image.astro";
---

<section class="section-padding bg-ivory-silk overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <div class="relative">
        <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
          Our Sanctuary
        </p>
        <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
          Where Every Detail<br class="hidden sm:inline" />
          <span class="gradient-text-gold">Whispers Luxury</span>
        </h2>
        <p class="mt-6 font-body text-base leading-relaxed text-taupe">
          At Amani, we believe true beauty begins in stillness. Our serene
          sanctuary in Westlands, Nairobi offers an escape from the rhythm of the
          city — a space where skilled hands and premium products converge to
          restore, refine, and rejuvenate.
        </p>
        <p class="mt-4 font-body text-base leading-relaxed text-taupe">
          Every therapist, nail artist, and aesthetician at Amani is rigorously
          trained and deeply passionate. We use only premium, ethically sourced
          products — because your skin deserves nothing less.
        </p>

        <div
          class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-8"
          data-animate-stagger
        >
          {[
            { label: "Happy Clients", target: 5000, suffix: "+" },
            { label: "Services Offered", target: 17, suffix: "" },
            { label: "Years of Excellence", target: 8, suffix: "+" },
            { label: "5-Star Reviews", target: 1200, suffix: "+" },
          ].map((stat) => (
            <div class="text-center">
              <p
                class="font-display text-[clamp(1.75rem,3vw,2.5rem)] font-bold text-espresso"
                data-counter={stat.target}
                data-suffix={stat.suffix}
              >
                0{stat.suffix}
              </p>
              <p class="font-body text-xs text-taupe mt-1.5">{stat.label}</p>
            </div>
          ))}
        </div>

        <a
          href="/about"
          class="mt-8 inline-flex items-center gap-2 font-body text-sm font-semibold tracking-[0.05em] uppercase text-gold-leaf hover:text-espresso transition-colors duration-[var(--duration-fast)] group"
        >
          Discover Our Story
          <svg
            class="h-4 w-4 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-1"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

      <div
        class="relative aspect-[4/3] rounded-[var(--radius-2xl)] overflow-hidden shadow-elevated"
        data-reveal
      >
        <Image
          src="/images/gallery/spa-suite.webp"
          alt="Signature spa suite at Amani Nails & Spa with ambient candlelight and plush towels"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-[var(--duration-slow)] group-hover:scale-105"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-gold-leaf/10 rounded-[var(--radius-2xl)] pointer-events-none" />
      </div>
    </div>
  </div>
</section>
