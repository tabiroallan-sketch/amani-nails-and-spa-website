---
const contactDetails = [
  {
    label: "Address",
    value: "Westlands, Nairobi, Kenya",
    icon: "map",
  },
  {
    label: "Phone",
    value: "+254 700 000 000",
    href: "tel:+254700000000",
    icon: "phone",
  },
  {
    label: "Email",
    value: "hello@amanispanairobi.com",
    href: "mailto:hello@amanispanairobi.com",
    icon: "mail",
  },
  {
    label: "Hours",
    value: "Mon–Sat: 8:00 AM – 8:00 PM\nSun: 10:00 AM – 6:00 PM",
    icon: "clock",
  },
];

const icons: Record<string, string> = {
  map: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
  phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  mail: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  clock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
};
---

<section class="section-padding bg-champagne-light overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
        Visit Us
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
        Find Your <span class="gradient-text-gold">Sanctuary</span>
      </h2>
      <p class="mt-4 font-body text-base text-taupe mb-14">
        Conveniently located in the heart of Westlands, Nairobi. We look forward
        to welcoming you.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-2 space-y-6" data-animate-stagger>
        {contactDetails.map((detail) => (
          <div class="flex gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-ivory-silk text-gold-leaf">
              <span class="h-5 w-5" set:html={icons[detail.icon]} />
            </div>
            <div>
              <h3 class="font-body text-xs uppercase tracking-[0.1em] text-taupe-warm font-semibold mb-1">
                {detail.label}
              </h3>
              {"href" in detail ? (
                <a
                  href={detail.href!}
                  class="font-body text-sm text-espresso hover:text-gold-leaf transition-colors duration-[var(--duration-fast)]"
                >
                  {detail.value}
                </a>
              ) : (
                <p class="font-body text-sm text-espresso leading-relaxed whitespace-pre-line">
                  {detail.value}
                </p>
              )}
            </div>
          </div>
        ))}

        <a
          href="/contact"
          class="mt-6 inline-flex items-center gap-2 font-body text-sm font-semibold tracking-[0.05em] uppercase text-gold-leaf hover:text-espresso transition-colors duration-[var(--duration-fast)] group"
        >
          Get Directions
          <svg
            class="h-4 w-4 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-1"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

      <div class="lg:col-span-3" data-reveal>
        <div class="relative aspect-[4/3] lg:aspect-auto lg:h-full min-h-[300px] rounded-[var(--radius-2xl)] overflow-hidden shadow-soft bg-ivory-silk">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.754!2d36.8033!3d-1.2611!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMcKwMTUnNDAuMCJTIDM2wrA0OCcxMS45IkU!5e0!3m2!1sen!2ske!4v1"
            width="100%"
            height="100%"
            style="border:0; min-height: 300px; position: absolute; inset: 0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Amani Nails & Spa location in Westlands, Nairobi"
          />
          <div class="absolute inset-0 ring-1 ring-inset ring-gold-leaf/10 rounded-[var(--radius-2xl)] pointer-events-none" />
        </div>
      </div>
    </div>
  </div>
</section>
