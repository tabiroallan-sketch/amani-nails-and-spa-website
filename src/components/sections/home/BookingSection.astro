---
import Scene3D from "../../three/Scene3D.tsx";
---

<section class="relative overflow-hidden bg-espresso" data-animate>
  <div class="absolute inset-0 z-0 opacity-10">
    <Scene3D scene="lotus" client:visible />
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-espresso via-espresso/95 to-espresso pointer-events-none z-[1]" />

  <div class="container-luxury relative z-10 py-24 md:py-32 text-center">
    <p class="font-body text-xs uppercase tracking-[0.2em] text-champagne-gold/60 mb-4">
      Book Now
    </p>
    <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-semibold text-champagne text-balance">
      Your Moment of<br />
      <span class="gradient-text-gold">Serenity Awaits</span>
    </h2>
    <p class="mt-4 font-body text-base text-champagne/70 max-w-xl mx-auto">
      Book your appointment today and discover why Amani is Nairobi's most
      coveted beauty and wellness destination.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/booking"
        class="inline-flex items-center justify-center px-10 py-5 bg-champagne-gold text-espresso font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] shadow-soft hover:shadow-elevated hover:bg-gold-leaf active:scale-[0.98]"
      >
        Schedule Your Visit
      </a>
      <a
        href="tel:+254700000000"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-champagne/20 text-champagne font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:bg-champagne/10 active:scale-[0.98]"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        +254 700 000 000
      </a>
    </div>
  </div>
</section>
