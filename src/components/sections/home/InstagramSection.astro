---
import Image from "../../ui/Image.astro";

const posts = [
  { id: 1, label: "Gel nail art", alt: "White marble-effect gel polish with subtle gold veining on natural nails at Amani Nails & Spa", src: "/images/gallery/gel-polish-marble.webp" },
  { id: 2, label: "Spa treatment room", alt: "Private treatment room featuring heated therapy bed and ambient lighting at Amani spa in Nairobi", src: "/images/gallery/treatment-room.webp" },
  { id: 3, label: "Manicure session", alt: "Luxury manicure treatment with professional nail polish application at a premium Nairobi salon", src: "/images/services/manicure.webp" },
  { id: 4, label: "Massage therapy", alt: "Therapeutic deep tissue massage technique in a tranquil treatment room with aromatherapy", src: "/images/gallery/deep-tissue-therapy.webp" },
  { id: 5, label: "Facial glow", alt: "Customised facial treatment with natural face mask and professional skincare at Amani", src: "/images/services/facials.webp" },
  { id: 6, label: "Amani interiors", alt: "Elegant salon waiting lounge with champagne bar and curated art at Amani Nails & Spa", src: "/images/gallery/salon-lounge.webp" },
];
---

<section class="section-padding bg-ivory-silk overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
        Follow Us
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
        <span class="gradient-text-gold">@amanispanairobi</span>
      </h2>
      <p class="mt-4 font-body text-base text-taupe">
        Follow us on Instagram for daily inspiration, behind-the-scenes moments,
        and exclusive offers.
      </p>
    </div>

    <div
      class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2 md:gap-3"
      data-animate-stagger
    >
      {posts.map((post) => (
        <a
          href="https://instagram.com/amanispanairobi"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative aspect-square overflow-hidden rounded-[var(--radius-sm)] bg-champagne transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated"
        >
          <Image
            src={post.src}
            alt={post.alt}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[var(--duration-slow)] group-hover:scale-110"
          />

          <div class="absolute inset-0 bg-espresso/0 transition-all duration-[var(--duration-normal)] group-hover:bg-espresso/50" />

          <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-all duration-[var(--duration-normal)] group-hover:opacity-100">
            <svg class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>

          <div class="absolute bottom-0 left-0 right-0 p-2 translate-y-full transition-transform duration-[var(--duration-normal)] group-hover:translate-y-0">
            <p class="font-body text-[10px] text-white/80 truncate">{post.label}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 text-center" data-animate>
      <a
        href="https://instagram.com/amanispanairobi"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 border border-gold-leaf text-gold-leaf font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:bg-gold-leaf hover:text-espresso active:scale-[0.98]"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        Follow @amanispanairobi
      </a>
    </div>
  </div>
</section>
