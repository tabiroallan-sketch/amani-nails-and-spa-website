---
import { getCollection } from "astro:content";
import Image from "../../ui/Image.astro";

const services = await getCollection("services");
services.sort((a, b) => a.data.order - b.data.order);

const categoryOrder = ["nails", "massages", "face", "packages"];
const featured = services.filter((s) =>
  ["nails", "massages", "face", "packages"].includes(s.data.category)
);
featured.sort(
  (a, b) =>
    categoryOrder.indexOf(a.data.category) -
    categoryOrder.indexOf(b.data.category)
);
const preview = featured.filter((_, i) => i < 4);

const icons: Record<string, string> = {
  nails: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l2 6-8 12-8-12 2-6z"/><path d="M6 9h12"/></svg>',
  massages: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21c0-4.418-3.582-8-8-8s-8 3.582-8 8"/></svg>',
  face: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/><circle cx="8.5" cy="9.5" r="1.5"/><circle cx="15.5" cy="9.5" r="1.5"/><path d="M15 15c-.5 1-1.5 1.5-3 1.5s-2.5-.5-3-1.5"/></svg>',
  packages: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c-4-3-8-6-8-11 0-3 4-8 8-8s8 5 8 8c0 5-4 8-8 11z"/></svg>',
};
---

<section class="section-padding bg-champagne-light overflow-hidden" data-animate>
  <div class="container-luxury">
    <div class="text-center max-w-2xl mx-auto">
      <p class="font-body text-xs uppercase tracking-[0.2em] text-taupe-warm mb-4">
        Our Craft
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3rem)] font-semibold text-espresso text-balance">
        Exceptional Services,<br />
        <span class="gradient-text-gold">Timeless Care</span>
      </h2>
      <p class="mt-4 font-body text-base text-taupe">
        Every treatment is a ritual of renewal. From the precision of our nail
        artistry to the depth of our therapeutic massages.
      </p>
    </div>

    <div
      class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
      data-animate-stagger
    >
      {preview.map((s) => (
        <a
          href={`/services/${s.slug}`}
          class="group relative flex flex-col rounded-[var(--radius-lg)] bg-warm-white shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated hover:-translate-y-1 overflow-hidden"
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-champagne">
            {s.data.image && (
              <Image
                src={s.data.image}
                alt={s.data.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-[var(--duration-slow)] group-hover:scale-110"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-warm-white/90 via-transparent to-transparent" />
            <div
              class={`absolute top-4 left-4 flex h-10 w-10 items-center justify-center rounded-full shadow-soft backdrop-blur-sm ${
                s.data.category === "nails"
                  ? "bg-rose-gold-light/90 text-rose-gold-deep"
                  : s.data.category === "massages"
                    ? "bg-sage-light/90 text-sage-whisper"
                    : s.data.category === "face"
                      ? "bg-champagne/90 text-gold-leaf"
                      : "bg-champagne/90 text-gold-leaf"
              }`}
            >
              <span class="h-5 w-5" set:html={icons[s.data.category]} />
            </div>
          </div>
          <div class="p-6 pb-4">
            <h3 class="font-display text-lg font-semibold text-espresso">
              {s.data.title}
            </h3>
            <p class="mt-2 font-body text-sm text-taupe leading-relaxed line-clamp-2">
              {s.data.description}
            </p>
          </div>

          <div class="mt-auto px-6 pb-6 flex items-center justify-between">
            <span class="font-display font-semibold text-gold-leaf">
              KES {s.data.price.toLocaleString()}
            </span>
            <span class="flex items-center gap-1 font-body text-[11px] uppercase tracking-[0.1em] font-semibold text-espresso group-hover:text-gold-leaf transition-colors duration-[var(--duration-fast)]">
              Book
              <svg
                class="h-3.5 w-3.5 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-0.5"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 text-center" data-animate>
      <a
        href="/services"
        class="inline-flex items-center justify-center px-8 py-4 border border-gold-leaf text-gold-leaf font-body text-sm font-semibold tracking-[0.05em] uppercase rounded-full transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:bg-gold-leaf hover:text-espresso active:scale-[0.98]"
      >
        View All Services
      </a>
    </div>
  </div>
</section>
