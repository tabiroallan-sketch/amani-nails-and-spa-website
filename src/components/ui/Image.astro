---
export interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager" | "auto";
  decoding?: "async" | "auto" | "sync";
  width?: number;
  height?: number;
}

const { src, alt, width, height } = Astro.props;
const base = src.replace(/\.[^.]+$/, "");
const loading = Astro.props.loading ?? "lazy";
const decoding = Astro.props.decoding ?? "async";
const cls = Astro.props.class ?? "";

const attrs: Record<string, string> = {};
if (width) attrs.width = String(width);
if (height) attrs.height = String(height);
---

<img
  src={src}
  alt={alt}
  class={cls}
  loading={loading}
  decoding={decoding}
  srcset={`
    ${base}/400w.webp 400w,
    ${base}/800w.webp 800w,
    ${base}/1200w.webp 1200w,
    ${src} 1920w
  `}
  sizes="(max-width: 400px) 400px, (max-width: 800px) 800px, (max-width: 1200px) 1200px, 1920px"
  {...attrs}
/>
