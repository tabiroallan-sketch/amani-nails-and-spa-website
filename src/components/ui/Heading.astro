---
export interface Props {
  tag?: "h1" | "h2" | "h3" | "h4";
  size?: "sm" | "md" | "lg" | "xl" | "2xl";
  as?: "span";
  color?: string;
}

const { tag: Tag = "h2", size = "lg", color = "text-espresso" } = Astro.props;

const sizes: Record<string, string> = {
  sm: "text-lg",
  md: "text-[clamp(1.25rem,3vw,1.75rem)]",
  lg: "text-[clamp(1.75rem,4vw,3rem)]",
  xl: "text-[clamp(2rem,5vw,3.5rem)]",
  "2xl": "text-[clamp(2.5rem,8vw,5rem)]",
};
---

<Tag class={`font-display font-semibold leading-[1.1] text-balance ${sizes[size]} ${color}`}>
  <slot />
</Tag>
