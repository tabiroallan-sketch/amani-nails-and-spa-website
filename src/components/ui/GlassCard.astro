---
export interface Props {
  padding?: "sm" | "md" | "lg";
  hover?: boolean;
}
const { padding = "md", hover = true } = Astro.props;
const paddings = { sm: "p-4", md: "p-6", lg: "p-8" };
---

<div class={`rounded-[var(--radius-card)] glass ${paddings[padding]} ${hover ? "hover:shadow-xl hover:-translate-y-1 transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)]" : ""}`}>
  <slot />
</div>
