---
export interface Props {
  title: string;
  description: string;
  icon?: "spa" | "nails" | "massage" | "facial" | "waxing" | "custom";
  image?: string;
  duration?: string;
  price?: string;
  href?: string;
  cta?: string;
  variant?: "compact" | "detailed" | "featured";
}

const {
  title,
  description,
  icon = "custom",
  image,
  duration,
  price,
  href = "#",
  cta = "Learn More",
  variant = "detailed",
} = Astro.props;

const icons: Record<string, string> = {
  spa: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c-4-3-8-6-8-11 0-3 4-8 8-8s8 5 8 8c0 5-4 8-8 11z"/><path d="M12 11c-1.5 0-3-1-3-3s1.5-3 3-3 3 1 3 3-1.5 3-3 3z"/></svg>`,
  nails: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l2 6-8 12-8-12 2-6z"/><path d="M6 9h12"/><path d="M9 3l1 6"/><path d="M15 3l-1 6"/></svg>`,
  massage: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21c0-4.418-3.582-8-8-8s-8 3.582-8 8"/><path d="M16 11.5c1.5-1 4-1.5 4-1.5"/><path d="M8 11.5c-1.5-1-4-1.5-4-1.5"/></svg>`,
  facial: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"/><circle cx="8.5" cy="9.5" r="1.5"/><circle cx="15.5" cy="9.5" r="1.5"/><path d="M15 15c-.5 1-1.5 1.5-3 1.5s-2.5-.5-3-1.5"/></svg>`,
  waxing: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  custom: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
};

const variantStyles: Record<string, string> = {
  compact: "flex items-center gap-4 p-4 rounded-[var(--radius-md)] bg-warm-white shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated hover:-translate-y-0.5",
  detailed: "group relative flex flex-col rounded-[var(--radius-lg)] bg-warm-white shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated hover:-translate-y-1 overflow-hidden",
  featured: "relative flex flex-col md:flex-row rounded-[var(--radius-2xl)] bg-gradient-to-br from-champagne-light to-warm-white shadow-soft transition-all duration-[var(--duration-normal)] ease-[var(--ease-luxury)] hover:shadow-elevated overflow-hidden",
};
---

<a href={href} class={variantStyles[variant]}>

  {variant === "compact" && (
    <>
      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-champagne text-gold-leaf">
        <span class="h-6 w-6" set:html={icons[icon]} />
      </div>
      <div class="flex-1 min-w-0">
        <h3 class="font-display font-semibold text-espresso truncate">{title}</h3>
        <p class="font-body text-sm text-taupe line-clamp-1">{description}</p>
      </div>
      {price && <span class="font-display font-semibold text-gold-leaf shrink-0">{price}</span>}
    </>
  )}

  {(variant === "detailed" || variant === "featured") && image && (
    <div class={`relative overflow-hidden ${variant === "detailed" ? "aspect-[4/3]" : "md:w-1/2 aspect-[4/3] md:aspect-auto"}`}>
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-all duration-[var(--duration-slow)] ease-[var(--ease-luxury)] group-hover:scale-105"
        loading="lazy"
      />
      {variant === "detailed" && (
        <div class="absolute inset-0 bg-gradient-to-t from-espresso/60 via-transparent to-transparent" />
      )}
    </div>
  )}

  <div class={`flex flex-col ${variant === "detailed" ? "p-6" : variant === "featured" ? "p-8 md:p-10 md:w-1/2" : ""}`}>
    {variant !== "compact" && (
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-champagne text-gold-leaf mb-4">
        <span class="h-6 w-6" set:html={icons[icon]} />
      </div>
    )}

    <h3 class="font-display text-xl font-semibold text-espresso">{title}</h3>
    <p class="mt-2 font-body text-sm leading-relaxed text-taupe">{description}</p>

    {(duration || price) && (
      <div class="mt-4 flex items-center gap-4 font-body text-sm">
        {duration && (
          <span class="flex items-center gap-1.5 text-taupe-warm">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {duration}
          </span>
        )}
        {price && (
          <span class="font-display font-semibold text-gold-leaf text-lg">{price}</span>
        )}
      </div>
    )}

    {variant !== "compact" && (
      <div class="mt-6 flex items-center gap-2 font-body text-sm font-semibold tracking-[0.05em] uppercase text-gold-leaf group-hover:text-espresso transition-colors duration-[var(--duration-fast)]">
        {cta}
        <svg class="h-4 w-4 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
    )}
  </div>
</a>
