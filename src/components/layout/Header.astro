---
import Navigation from "./Navigation.astro";
import MobileNav from "./MobileNav.astro";
---

<header class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="container-luxury flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3" aria-label="Amani Nails & Spa — Home">
      <span class="font-display text-2xl font-semibold text-espresso tracking-tight">
        Amani
      </span>
      <span class="hidden sm:inline font-body text-xs text-warm-taupe uppercase tracking-[0.15em]">
        Nails & Spa
      </span>
    </a>

    <Navigation />
    <MobileNav />
  </div>
</header>
